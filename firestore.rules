rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función auxiliar: verifica que el usuario haya iniciado sesión
    function isSignedIn() {
      return request.auth != null;
    }

    // Colección de Usuarios: Todos pueden leer, pero solo el dueño puede modificar su perfil
    match /users/{userId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update, delete: if isSignedIn() && request.auth.uid == userId;
    }

    // Colección de Listados (Marketplace)
    match /listings/{listingId} {
      allow read: if true;
      allow create: if true; // Temporarmente abierto
      allow update, delete: if isSignedIn(); 
    }
    
    // Colección de Mensajes y Conversaciones (CHAT)
    match /conversations/{convId} {
      allow read, write: if isSignedIn();
      
      // Mensajes dentro de una conversación
      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // Configuración para anuncios y chats de moderación
    match /ads/{adId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    // Resto de documentos por defecto (Seguridad Básica)
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
